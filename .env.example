# ─── Application ─────────────────────────────────────────────────────────────
# Set to "prod" in production so cookies use Secure + SameSite=None
NEXT_PUBLIC_APP_ENV=dev

# ─── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── OpenAI (server-side chatbot only) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
